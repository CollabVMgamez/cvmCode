{
  "name": "cvmcode",
  "version": "1.0.2",
  "description": "cvmCode: a production-quality CLI coding agent for real repositories",
  "type": "module",
  "bin": {
    "cvmcode": "dist/cli/index.js",
    "cvmCode": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "examples"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "agent",
    "coding-agent",
    "openai-compatible",
    "developer-tools",
    "terminal"
  ],
  "author": "cvmCode",
  "license": "MIT",
  "packageManager": "pnpm@10.7.0",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "prompts": "^2.4.2",
    "yaml": "^2.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.14",
    "electron": "^41.0.3",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
